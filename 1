local speedLabel = Instance.new("TextLabel")
speedLabel.Parent = Frame
speedLabel.BackgroundTransparency = 1
speedLabel.Position = UDim2.new(0.35, 0, 0.82, 0)
speedLabel.Size = UDim2.new(0, 100, 0, 25)
speedLabel.Font = Enum.Font.Gotham
speedLabel.Text = "速度: 1"
speedLabel.TextColor3 = Color3.new(1, 1, 1)
speedLabel.TextSize = 14

local speeds = 1
local nowe = false
local tpwalking = false
local speaker = game.Players.LocalPlayer

-- 开启/关闭飞行
onoff.MouseButton1Click:Connect(function()
    nowe = not nowe
    if nowe then
        onoff.Text = "飞行中..."
        onoff.BackgroundColor3 = Color3.fromRGB(80, 255, 80)
        
        speaker.Character.Humanoid.PlatformStand = true
        game.Players.LocalPlayer.Character.Animate.Disabled = true
    else
        onoff.Text = "开启飞行"
        onoff.BackgroundColor3 = Color3.fromRGB(255, 200, 60)
        speaker.Character.Humanoid.PlatformStand = false
        game.Players.LocalPlayer.Character.Animate.Disabled = false
    end
end)

-- 关闭飞行并销毁界面（新增功能）
closeBtn.MouseButton1Click:Connect(function()
    nowe = false
    tpwalking = false
    
    if speaker.Character and speaker.Character:FindFirstChild("Humanoid") then
        speaker.Character.Humanoid.PlatformStand = false
        speaker.Character.Animate.Disabled = false
    end
    
    -- 销毁界面
    main:Destroy()
end)

up.MouseButton1Click:Connect(function()
    if speaker.Character and speaker.Character:FindFirstChild("HumanoidRootPart") then
        speaker.Character.HumanoidRootPart.CFrame = speaker.Character.HumanoidRootPart.CFrame * CFrame.new(0, 2, 0)
    end
end)

down.MouseButton1Click:Connect(function()
    if speaker.Character and speaker.Character:FindFirstChild("HumanoidRootPart") then
        speaker.Character.HumanoidRootPart.CFrame = speaker.Character.HumanoidRootPart.CFrame * CFrame.new(0, -2, 0)
    end
end)

plus.MouseButton1Click:Connect(function()
    speeds = speeds + 1
    speedLabel.Text = "速度: " .. speeds
end)

minus.MouseButton1Click:Connect(function()
    if speeds > 1 then
        speeds = speeds - 1
        speedLabel.Text = "速度: " .. speeds
    end
end)

-- 飞行核心循环
spawn(function()
    while true do
        if nowe and speaker.Character and speaker.Character:FindFirstChild("Humanoid") then
            local hum = speaker.Character.Humanoid
            if hum.MoveDirection.Magnitude > 0 then
                speaker.Character:TranslateBy(hum.MoveDirection * speeds * 0.5)
            end
        end
        task.wait()
    end
end)

print("HHP 飞行脚本已加载 - 汉化加密版")
